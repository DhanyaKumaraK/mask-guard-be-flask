# =============================================================================
# Mask Guard — Flask Backend  |  Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env     (Linux / macOS)
#   copy .env.example .env   (Windows)
#
# NEVER commit the actual .env file — it is listed in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------

# Secret key used to sign session cookies.
# Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=my-secret-key-here

# Flask run host and port (used by app.run())
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Set to "development" for auto-reload and debug mode, "production" otherwise.
FLASK_ENV=development

# Allowed CORS origin(s) for the React front-end (comma-separated if multiple)
CORS_ORIGIN=http://localhost:5173


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Path to the SQLite database file (relative or absolute)
DATABASE_PATH=project.db


# -----------------------------------------------------------------------------
# ChromaDB  (Vector Store — for RAG enhancements)
# -----------------------------------------------------------------------------

# Directory where ChromaDB persists its data
CHROMA_PATH=./chroma_db

# Name of the ChromaDB collection used to store PII knowledge-base embeddings
COLLECTION_NAME=PII_REGISTRY


# -----------------------------------------------------------------------------
# Ollama  (Local LLM)
# -----------------------------------------------------------------------------

# Base URL of the running Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Name of the Ollama model used for PII masking / generation
GENERATION_MODEL=llama3

# Name of the Ollama model used for generating embeddings
EMBEDDING_MODEL=nomic-embed-text


# -----------------------------------------------------------------------------
# RAG / Inference Settings
# -----------------------------------------------------------------------------

# Number of top results to retrieve from the vector store for context (k in kNN)
TOP_K=5

# Sampling temperature for the generation model (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.0


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Path to the log file (leave blank to disable file logging)
LOG_FILE=maskguard.log
